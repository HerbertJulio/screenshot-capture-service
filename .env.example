# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
API_KEY=your-api-key-here
WEBHOOK_SECRET=your-webhook-secret-here

# Storage (S3-compatible)
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=scs-screenshots
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
CDN_BASE_URL=https://screenshots.example.com

# Database
DB_PATH=./data/scs.db

# Capture
CAPTURE_TIMEOUT_MS=30000
CAPTURE_DELAY_AFTER_LOAD_MS=2000
MAX_CONCURRENT_CAPTURES=3
BROWSER_RECYCLE_AFTER=10

# URL Allowlist (comma-separated regex patterns, .* allows all)
URL_ALLOWLIST_PATTERNS=.*
