# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
API_KEY=your-api-key-here
WEBHOOK_SECRET=your-webhook-secret-here

# Storage (Azion Edge Storage - S3-compatible)
# Docs: https://www.azion.com/en/documentation/products/store/edge-storage/
S3_ENDPOINT=https://s3.us-east-005.azionstorage.net
S3_REGION=us-east-005
S3_BUCKET=screenshot-captures
S3_ACCESS_KEY_ID=your-azion-access-key
S3_SECRET_ACCESS_KEY=your-azion-secret-key

# CDN (Azion Edge Application serving the bucket)
CDN_BASE_URL=https://your-domain.map.azionedge.net

# Database
DB_PATH=./data/scs.db

# Capture
CAPTURE_TIMEOUT_MS=30000
CAPTURE_DELAY_AFTER_LOAD_MS=2000
MAX_CONCURRENT_CAPTURES=3
BROWSER_RECYCLE_AFTER=10

# URL Allowlist (comma-separated regex patterns, .* allows all)
URL_ALLOWLIST_PATTERNS=.*
